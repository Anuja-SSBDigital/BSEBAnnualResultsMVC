<style>
    body {
        font-family: Arial, sans-serif;
        margin: 20px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    .table-responsive {
        width: 100%;
        overflow-x: auto;
    }

    th, td {
        border: 1px solid black;
        padding: 7px;
        text-align: left;
    }

    th {
        background-color: #f2f2f2;
    }

    .header {
        text-align: center;
        margin-bottom: 20px;
    }

    body {
        font-family: Arial, sans-serif;
        margin: 20px;
        padding: 0;
    }

    .container {
        width: 80%;
        margin: auto;
        /*border: 2px solid black;*/
        padding: 20px;
    }

    .header {
        text-align: center;
        font-size: 20px;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .logo {
        text-align: center;
        margin-bottom: 10px;
    }

        .logo img {
            width: 80px;
        }

    .marksheet {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 10px;
    }

        .marksheet, .marksheet th, .marksheet td {
            border: 1px solid black;
        }

            .marksheet th, .marksheet td {
                padding: 10px;
                text-align: center;
            }

    .subject-group {
        text-align: left;
        font-weight: bold;
        background-color: #e0e0e0;
    }

    .watermark {
        position: fixed;
        top: 40%;
        left: 50%;
        transform: translate(-50%, -50%) rotate(-30deg);
        font-size: 70px;
        font-weight: bold;
        color: rgba(0, 0, 0, 0.3);
        z-index: 9999;
        white-space: nowrap;
        pointer-events: none;
        text-align: center;
    }

    .watermark-subtext {
        display: block;
        font-size: 20px;
        font-weight: normal;
        margin-top: 10px;
        color: rgba(0, 0, 0, 0.4);
    }

    @@page {
        margin: 0px;
    }

    .print-btn-container {
        text-align: center;
        margin-top: 10px;
        margin-bottom: 20px;
    }

    .noprint {
        display: inline-block;
        width: 120px;
        padding: 10px;
        font-size: 16px;
        background-color: #28a745;
        color: white;
        border: none;
        cursor: pointer;
        border-radius: 5px;
    }

    /*  .text_center th,
            .text_center td {
                text-align: center;
            } */
    .subject-group-header {
        text-align: left !important;
    }

    .text_center th,
    .text_center td:not(.subject-group-header) {
        text-align: center;
    }

   

    @@media print {
        
        .noprintinside {
            visibility: hidden;
        }
    }
</style>
<script>
    function printDiv() {

        window.print();
    }
      function goBack() {
        window.location.href = '@Url.Action("Index", "Result")'; // change controller if needed
    }
</script>
<center>
    <button class="noprint btn btn-success" onclick="printDiv()"
            style="
        width: 120px;
        padding: 5px;
        margin-bottom: 4px;
        background: #28a745; /* Green color */
        color: #fff; /* White text */
        border: 2px solid #28a745; /* Green border */
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    "
            onmouseover="this.style.background='#218838'; this.style.borderColor='#218838';"
            onmouseout="this.style.background='#28a745'; this.style.borderColor='#28a745';">
        PRINT
    </button>
    <button class="noprintinside btn btn-success" onclick="printDiv();" style="width:120px;padding: 5px;     margin-bottom: 4px;background:#28a745; color:#fff;border:2px solid #28a745;border-radius:6px; font-weight:600;">PRINT</button>
    <button class="noprintinside btn btn-secondary" onclick="goBack()" style="width:120px;    padding: 5px;    margin-bottom: 4px; background:#6c757d; color:#fff;border-radius:6px; font-weight:600;"> BACK </button>
    <button class="noprint btn btn-secondary" onclick="goBack()" style="width:120px;    padding: 5px;    margin-bottom: 4px; background:#6c757d; color:#fff;border-radius:6px; font-weight:600;"> BACK </button>
</center>
<div id="pagewrap">
    <style>
        @@page {
            size: A4 portrait;
            /* margin: 10mm 12mm; */
        }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid black;
            padding: 6px;
            font-size: 11pt;
        }

        .watermark {
            position: fixed !important;
            top: 40% !important;
            left: 50% !important;
            transform: translate(-50%, -50%) rotate(-30deg) !important;
            font-size: 60pt !important;
            color: rgba(0,0,0,0.25) !important;
            z-index: 9999 !important;
        }

        .bottom-tag {
            position: fixed !important;
            bottom: 5px !important;
            right: 10px !important;
            font-size: 8px !important;
            color: #000 !important;
        }

        .noprint {
            display: none !important;
        }
    </style>
    <div class="watermark">
        WEB COPY
        <span class="watermark-subtext">
            1. Bihar School Examination Board, Patna is not responsible for any <br>
            inadvertent error that may have crept in the results being published <br>
            on the NET. <br>
            2. The results published on the NET are for immediate information to <br>
            the examinees. <br>
            3. This is not a valid document.
        </span>
    </div>
    <table>
        <!-- HEADER -->
        <tr>
            <td>
                <table>
                    <tr>
                        <td style="border:1px solid #000; text-align:center; width:100px;">
                            <img src="~/img/logo.png" style="width:80px;" alt="BSEB" />
                        </td>
                        <td style="border:1px solid #000; text-align:center;">
                            <h3 style="margin: 5px; font-size: 18px; font-weight: 700; color: #000; font-family: arial;">Bihar School Examination Board</h3>
                            <p style="margin: 5px; font-size: 18px; font-weight: 700; color: #000; font-family: arial;">RESULT</p>
                            <h4 style="margin: 5px; font-size: 18px; font-weight: 700; color: #000; font-family: arial;">INTERMEDIATE ANNUAL EXAMINATION-2026</h4>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>

        <!-- STUDENT INFO -->
        <tr>
            <td>
                <table>
                    <tr>
                        <td>BSEB Unique Id</td>
                        <td>@s.BsebUniqueID</td>
                    </tr>
                    <tr>
                        <td>Student's Name</td>
                        <td>@s.NameoftheCandidate</td>
                    </tr>
                    <tr>
                        <td>Father's Name</td>
                        <td>@s.FathersName</td>
                    </tr>
                    <tr>
                        <td>School/College Name</td>
                        <td>@s.CollegeName</td>
                    </tr>
                    <tr>
                        <td>Roll Code</td>
                        <td>@s.RollCode</td>
                    </tr>
                    <tr>
                        <td>Roll Number</td>
                        <td>@s.RollNo</td>
                    </tr>
                    <tr>
                        <td>Registration Number</td>
                        <td>@s.RegistrationNo</td>
                    </tr>
                    <tr>
                        <td>Faculty</td>
                        <td>@s.FACULTY</td>
                    </tr>
                </table>
            </td>
        </tr>

        <!-- MARKS HEADER -->
        <tr>
            <td><strong>Marks Details</strong></td>
        </tr>
        <tr>
            <td>
                <table class="text_center">
                    <tr>
                        <th rowspan="2">Subject</th>
                        <th rowspan="2">Full Marks</th>
                        <th rowspan="2">Pass Marks</th>
                        <th rowspan="2">Theory</th>
                        <th rowspan="2">Practical</th>
                        @if (Model.Student.IsCCEMarks == 1)
                        {
                            <th rowspan="2">CCE</th>
                        }
                        <th colspan="2">Regulation</th>
                        <th rowspan="2">Subject Total</th>
                    </tr>
                    <tr>
                        <th>Th.</th>
                        <th>Pr.</th>
                    </tr>

                    @* ── COMPULSORY ── *@
                    @if (Model.CompulsorySubjects.Any())
                    {
                        <tr>
                            <td colspan="8" class="subject-group-header"><strong>1. अनिवार्य (Compulsory)</strong></td>

                        </tr>
                        @*   foreach (var sub in Model.CompulsorySubjects)
                            {
                                @Html.Partial("_SubjectRow", sub)
                            } *@

                        @foreach (var sub in Model.CompulsorySubjects)
                        {
                            @Html.Partial("_SubjectRow", sub, new ViewDataDictionary(ViewData)
                            {
                                { "IsCCEMarks", Model.Student.IsCCEMarks }
                            })
                                        }
                    }

                    @* ── ELECTIVE ── *@
                    @if (Model.ElectiveSubjects.Any())
                    {
                        <tr>
                            <td colspan="8" class="subject-group-header"><strong>2. ऐच्छिक (Elective)</strong></td>
                        </tr>
                        @*  foreach (var sub in Model.ElectiveSubjects)
                            {
                                @Html.Partial("_SubjectRow", sub)
                            } *@
                        @foreach (var sub in Model.ElectiveSubjects)
                        {
                            @Html.Partial("_SubjectRow", sub, new ViewDataDictionary(ViewData)
                            {
                                { "IsCCEMarks", Model.Student.IsCCEMarks }
                            })
                                        }
                    }

                    @* ── ADDITIONAL ── *@
                    @if (Model.AdditionalSubjects.Any())
                    {
                        <tr>
                            <td colspan="8" class="subject-group-header"> <strong>3. अतिरिक्त Additional</strong> </td>
                        </tr>
                        @*  foreach (var sub in Model.AdditionalSubjects)
                            {
                                @Html.Partial("_SubjectRow", sub)
                            } *@

                        @foreach (var sub in Model.AdditionalSubjects)
                        {
                            @Html.Partial("_SubjectRow", sub, new ViewDataDictionary(ViewData)
                            {
                                { "IsCCEMarks", Model.Student.IsCCEMarks }
                            })
                                        }
                    }

                    @* ── VOCATIONAL ── *@
                    @if (Model.VocationalSubjects.Any())
                    {
                        <tr>
                            <td colspan="8" class="subject-group-header"><strong>Vocational Trade</strong></td>
                        </tr>
                        @foreach (var sub in Model.VocationalSubjects)
                        {
                            @Html.Partial("_SubjectRow", sub, new ViewDataDictionary(ViewData)
                            {
                                { "IsCCEMarks", Model.Student.IsCCEMarks }
                            })
                                        }
                    }
                </table>
            </td>
        </tr>

        <!-- FINAL RESULT -->
        <tr>
            <td>
                <table>
                    <tr><td colspan="2"><strong>Final Result:</strong></td></tr>
                    <tr>
                        <td style="width:20%;"><strong>Aggregate Marks:</strong></td>
                        <td>@s.TotalAggregateMarkinNumber</td>
                    </tr>
                    <tr>
                        <td><strong>Result/Division:</strong></td>
                        <td>@s.DIVISION</td>
                    </tr>
                </table>
            </td>
        </tr>

        <!-- ABBREVIATIONS -->
        <tr>
            <td style="text-align:center; text-decoration:underline;">
                <strong>Abbreviations Used:</strong>
            </td>
        </tr>
        <tr>
            <td>
                <table>
                    <tr>
                        <td>* - Grace</td>
                        <td>@@ - Swapping</td>
                        <td># - Greater Marks of Last Year</td>
                        <td>D - Distinction</td>
                        <td>F - Fail</td>
                        <td>U/R - Under Regulation</td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
    <table>

        <tr>
            <td style="float: right; border: none; font-size: 7px;">**</td>

        </tr>
    </table>
</div>
@* <div class="bottom-tag">SSBD</div> *@