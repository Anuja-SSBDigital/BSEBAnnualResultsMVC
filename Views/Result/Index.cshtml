@{
    ViewBag.Title = "BSEB Result";
}
<div style="max-width:400px; margin:80px auto; font-family:Arial;">
    <h3>BSEB Intermediate Result 2026</h3>
    @if (ViewBag.Error != null)
    {
        <p style="color:red;">@ViewBag.Error</p>
    }
    @using (Html.BeginForm("GetResult", "Result", FormMethod.Post))
    {
        <table>
            <tr>
                <td>Roll Code:</td>
                <td><input type="text" name="rollcode" required /></td>
            </tr>
            <tr>
                <td>Roll Number:</td>
                <td><input type="text" name="rollno" required /></td>
            </tr>
            <tr>
                <td colspan="2">
                    <button type="submit">Get Result</button>
                </td>
            </tr>
        </table>
    }
</div>