@{
    ViewBag.Title = "BSEB Result";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BSEB Result - Intermediate Annual Examination-2026</title>

    <!-- Bootstrap CSS (same as original) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        /* EXACT SAME STYLES FROM ORIGINAL */
        body {
            background: #f5f7fa;
            font-family: 'Arial', sans-serif;
        }

        .login {
            max-width: 1200px;
            margin: 50px auto;
            display: flex;
            min-height: 500px;
            box-shadow: 0 0 20px rgba(0,0,0,.1);
            border-radius: 10px;
            overflow: hidden;
        }

        .left-box {
            flex: 1;
            background: white;
            padding: 50px 40px;
        }

        .right-box {
            flex: 1;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            position: relative;
        }

            .right-box img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .logo {
            text-align: center;
            margin-bottom: 40px;
        }

            .logo img {
                width: 80px;
                height: auto;
                margin-bottom: 15px;
            }

            .logo h1 {
                font-size: 28px;
                font-weight: 700;
                color: #333;
                margin: 0;
                font-family: 'Playfair Display', serif;
            }

            .logo p {
                color: #666;
                margin: 5px 0 0;
                font-size: 16px;
            }

        .login-form .form-group {
            margin-bottom: 25px;
        }

        .form-control {
            height: 50px;
            padding: 0 20px;
            font-size: 16px;
            border: 2px solid #e1e5e9;
            border-radius: 5px;
            transition: all .3s;
            background: #f8f9fa;
        }

            .form-control:focus {
                border-color: #667eea;
                box-shadow: 0 0 0 0.2rem rgba(102,126,234,.25);
                background: white;
            }

        .btn {
            width: 100%;
            height: 50px;
            font-size: 16px;
            font-weight: 600;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 5px;
            color: white;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all .3s;
        }

            .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(102,126,234,.3);
            }

        /* CAPTCHA STYLES - EXACT SAME */
        .cpta-box {
            text-align: center;
            margin-bottom: 25px;
            padding: 20px;
            background: #f5f5f5;
            border-radius: 8px;
            display: inline-block;
        }

        #generatedCaptcha {
            font-size: 24px;
            font-weight: bold;
            color: #0037FF;
            letter-spacing: 4px;
            padding: 12px 20px;
            background: #e0eaff;
            border-radius: 5px;
            user-select: none;
            display: inline-block;
            margin-right: 15px;
            min-width: 120px;
        }

        .cpta-box button {
            padding: 10px 18px;
            font-size: 14px;
            font-weight: bold;
            color: #000;
            background-color: #e0e0e0;
            border: 1px solid #ccc;
            border-radius: 5px;
            cursor: pointer;
            vertical-align: middle;
        }

            .cpta-box button:hover {
                background-color: #e0e0e0;
                color: #000;
            }

        .error-msg {
            color: #dc3545;
            font-size: 14px;
            margin-top: 5px;
            display: none;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .login

        {
            flex-direction: column;
            margin: 20px;
        }

        .right-box {
            height: 250px;
        }

        .left-box {
            padding: 30px 20px;
        }

        }
    </style>
</head>
<body>
    <div class="login">
        <div class="left-box">
            <div class="logo text-center">
                <img src="@Url.Content("~/img/bseorissa-logo-w.png")" alt="BSEB Logo" onerror="this.style.display='none'" />
                <h1 class="playfair-display">Bihar School Examination Board</h1>
                <p>RESULT<br>INTERMEDIATE ANNUAL EXAMINATION-2026</p>
            </div>

            <div class="login-form">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                @using (Html.BeginForm("GetResult", "Result", FormMethod.Post, new { id = "resultForm" }))
                {
                    <div class="form-group">
                        @Html.TextBox("rollcode", null, new { @class = "form-control", placeholder = "Enter Roll Code", autocomplete = "off", required = "required", id = "rollcode" })
                        <div class="error-msg" id="rollcodeError">Please Enter Roll Code</div>
                    </div>

                    <div class="form-group">
                        @Html.TextBox("rollno", null, new { @class = "form-control", placeholder = "Enter Roll Number", autocomplete = "off", required = "required", id = "rollno" })
                        <div class="error-msg" id="rollnoError">Please Enter Roll Number</div>
                    </div>

                    <div class="form-group cpta-box">
                        <span id="generatedCaptcha"></span>
                        <button type="button" onclick="generateCaptcha()" id="refreshCaptcha">⟳ Refresh</button>
                    </div>

                    <div class="form-group">
                        @Html.TextBox("captcha", null, new { @class = "form-control", placeholder = "Enter CAPTCHA", autocomplete = "off", id = "captchaInput" })
                        <div class="error-msg" id="captchaError">Incorrect CAPTCHA</div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary" id="btnSubmit">View Result</button>
                    </div>
                }
            </div>
        </div>

        <div class="right-box">
            <img src="@Url.Content("~/img/img11.jpg")" alt="BSEB Background" onerror="this.src='https://via.placeholder.com/600x500/667eea/ffffff?text=BSEB'" />
        </div>
    </div>

    <!-- jQuery & Bootstrap JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/js/bootstrap.min.js"></script>

    <script>
        // CAPTCHA GENERATION
        function generateCaptcha() {
            let captcha = Math.floor(100000 + Math.random() * 900000); // 6-digit
            let capElement = document.getElementById("generatedCaptcha");
            capElement.innerText = captcha;
            capElement.dataset.value = captcha;
            document.getElementById("captchaInput").value = ""; // Clear input
            hideAllErrors();
        }

        // FORM VALIDATION
        function validateForm() {
            let isValid = true;
            hideAllErrors();

            // Roll Code
            let rollcode = document.getElementById("rollcode").value.trim();
            if (!rollcode) {
                showError("rollcodeError", "Please Enter Roll Code");
                isValid = false;
            }

            // Roll Number
            let rollno = document.getElementById("rollno").value.trim();
            if (!rollno) {
                showError("rollnoError", "Please Enter Roll Number");
                isValid = false;
            }

            // CAPTCHA
            let userCaptcha = document.getElementById("captchaInput").value.trim();
            let generatedCaptcha = document.getElementById("generatedCaptcha").dataset.value;

            if (!userCaptcha) {
                showError("captchaError", "Please Enter CAPTCHA");
                isValid = false;
            } else if (userCaptcha !== generatedCaptcha) {
                showError("captchaError", "Incorrect CAPTCHA");
                generateCaptcha(); // Regenerate on wrong attempt
                isValid = false;
            }

            return isValid;
        }

        function showError(errorId, message) {
            document.getElementById(errorId).textContent = message;
            document.getElementById(errorId).style.display = "block";
        }

        function hideAllErrors() {
            document.querySelectorAll('.error-msg').forEach(el => {
                el.style.display = "none";
            });
        }

        // LIVE VALIDATION
        document.addEventListener('DOMContentLoaded', function() {
            generateCaptcha(); // Initial CAPTCHA

            // Real-time validation
            ['rollcode', 'rollno', 'captchaInput'].forEach(id => {
                document.getElementById(id).addEventListener('input', function() {
                    if (this.value.trim()) {
                        document.getElementById(this.id + 'Error').style.display = 'none';
                    }
                });
            });

            // Form submit
            document.getElementById('resultForm').addEventListener('submit', function(e) {
                if (!validateForm()) {
                    e.preventDefault();
                }
            });
        });
    </script>
</body>
</html>