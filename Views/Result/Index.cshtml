@{
    ViewBag.Title = "BSEB Result";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BSEB Result 2026</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            font-family: 'Arial', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 15px;
        }

        .container {
            width: 100%;
            max-width: 850px; /* COMPACT 2-SIDE */
            height: 520px; /* FIXED HEIGHT - NO SCROLL */
            background: white;
            border-radius: 20px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.15);
            overflow: hidden;
            display: flex;
            position: relative;
        }

        .left-panel {
            flex: 1;
            padding: 35px 30px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .right-panel {
            flex: 1;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            position: relative;
            overflow: hidden;
        }

        .logo-section {
            text-align: center;
            margin-bottom: 25px;
        }

        .logo {
            width: 60px;
            height: 60px;
            background: rgba(255,255,255,0.2);
            border-radius: 15px;
            margin: 0 auto 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            font-weight: bold;
            color: white;
            backdrop-filter: blur(10px);
        }

        .title {
            color: #333;
            font-size: 22px;
            font-weight: 700;
            margin: 0 0 4px 0;
            line-height: 1.2;
        }

        .subtitle {
            color: #666;
            font-size: 14px;
            margin: 0;
            line-height: 1.3;
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-control {
            width: 100%;
            height: 42px;
            padding: 0 14px;
            font-size: 15px;
            border: 2px solid #e8ecf4;
            border-radius: 10px;
            transition: all 0.3s;
            background: #fafbff;
        }

            .form-control:focus {
                outline: none;
                border-color: #667eea;
                background: white;
                box-shadow: 0 0 0 3px rgba(102,126,234,0.1);
            }

        /* COMPACT CAPTCHA ROW */
        .captcha-container {
            display: flex;
            gap: 10px;
            margin-bottom: 18px;
            padding: 14px;
            background: #f8f9ff;
            border: 2px solid #e8ecf4;
            border-radius: 10px;
            align-items: center;
        }

        #generatedCaptcha {
            flex: 1;
            font-size: 18px;
            font-weight: bold;
            color: #0037FF;
            letter-spacing: 1.5px;
            padding: 8px 10px;
            background: #e0eaff;
            border-radius: 6px;
            text-align: center;
            min-height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .captcha-refresh {
            width: 38px;
            height: 38px;
            border: none;
            background: #e0e0e0;
            border-radius: 8px;
            font-size: 14px;
            font-weight: bold;
            color: #333;
            cursor: pointer;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .captcha-refresh:hover {
                background: #d0d0d0;
            }

        .btn-submit {
            width: 100%;
            height: 44px;
            background: linear-gradient(135deg, #000000 0%, #333333 100%);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: all 0.3s;
        }

            .btn-submit:hover {
                transform: translateY(-1px);
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
            }

        .error {
            color: #dc3545;
            font-size: 12px;
            margin-top: 4px;
            display: none;
        }

        .alert-error {
            background: #fee;
            color: #c33;
            padding: 10px 14px;
            border-radius: 8px;
            border-left: 3px solid #dc3545;
            margin-bottom: 18px;
            font-size: 13px;
            line-height: 1.4;
        }

        /* RIGHT PANEL IMAGE */
        .right-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            /* opacity: 0.85; */
        }

        .right-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(102,126,234,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* MOBILE - STACK VERTICALLY */
        @@media (max-width: 768px) {
            .container

        {
            max-width: 100%;
            height: auto;
            flex-direction: column;
            max-height: 95vh;
        }

        .right-panel {
            height: 180px;
        }

        .left-panel {
            padding: 25px 20px;
        }

        .captcha-container {
            flex-direction: column;
            gap: 8px;
            padding: 12px;
        }

        .captcha-refresh {
            width: 100%;
        }

        }
    </style>
</head>
<body>
    <div class="container">
        <!-- LEFT FORM PANEL -->
        <div class="left-panel">
            <div class="logo-section">
                <div class="logo">
                    <img src="@Url.Content("~/img/bseorissa-logo-w.png")" alt="BSEB Logo" onerror="this.style.display='none'" style="width:70px" />
                </div>
                <h2 class="title">Bihar School Examination Board</h2>
                <p class="subtitle"><small>RESULT</small> <br><small>INTERMEDIATE ANNUAL EXAMINATION 2026</small></p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert-error">@ViewBag.Error</div>
            }

            @using (Html.BeginForm("GetResult", "Result", FormMethod.Post, new { id = "resultForm" }))
            {
                <div class="form-group">
                    <input type="text" name="rollcode" class="form-control"
                           placeholder="Enter Roll Code" autocomplete="off" required
                           id="rollcode" maxlength="10" />
                    <div class="error" id="rollcodeError">Please Enter Roll Code</div>
                </div>

                <div class="form-group">
                    <input type="text" name="rollno" class="form-control"
                           placeholder="Enter Roll Number" autocomplete="off" required
                           id="rollno" maxlength="10" />
                    <div class="error" id="rollnoError">Please Enter Roll Number</div>
                </div>

                <div class="captcha-container">
                    <span id="generatedCaptcha">000000</span>
                    <button type="button" class="captcha-refresh" onclick="generateCaptcha()" title="Refresh">⟳</button>
                </div>

                <div class="form-group">
                    <input type="text" name="captcha" class="form-control"
                           placeholder="Enter CAPTCHA" autocomplete="off" id="captchaInput" maxlength="6" />
                    <div class="error" id="captchaError">Please Enter Correct CAPTCHA</div>
                </div>

                <button type="submit" class="btn-submit">View Result</button>
            }
        </div>

        <!-- RIGHT IMAGE PANEL -->
        <div class="right-panel">
            <img src="@Url.Content("~/img/img11.jpg")" alt="BSEB" class="right-image"
                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'" />
           @*  <div class="right-overlay">
                <div style="color: rgba(255,255,255,0.9); font-size: 14px; text-align: center;">
                    Bihar School<br>Examination Board
                </div>
            </div> *@
        </div>
    </div>

    <script>
        function generateCaptcha() {
            const captcha = Math.floor(100000 + Math.random() * 900000);
            document.getElementById('generatedCaptcha').textContent = captcha;
            document.getElementById('generatedCaptcha').dataset.value = captcha;
            document.getElementById('captchaInput').value = '';
            hideAllErrors();
        }

        function showError(id, message) {
            const errorEl = document.getElementById(id);
            if (errorEl) {
                errorEl.textContent = message;
                errorEl.style.display = 'block';
            }
        }

        function hideAllErrors() {
            document.querySelectorAll('.error').forEach(el => {
                el.style.display = 'none';
            });
        }

        // Map input IDs to their corresponding error div IDs
        const errorMap = {
            'rollcode': 'rollcodeError',
            'rollno': 'rollnoError',
            'captchaInput': 'captchaError'
        };

        document.addEventListener('DOMContentLoaded', function () {
            generateCaptcha();

            // Live input validation
            document.querySelectorAll('.form-control').forEach(input => {
                input.addEventListener('input', function () {
                    if (this.value.trim()) {
                        const errorId = errorMap[this.id];
                        if (errorId) {
                            const errorEl = document.getElementById(errorId);
                            if (errorEl) errorEl.style.display = 'none';
                        }
                    }
                });
            });

            // Form validation
            document.getElementById('resultForm').onsubmit = function (e) {
                let isValid = true;
                hideAllErrors();

                const rollcode = document.getElementById('rollcode').value.trim();
                const rollno = document.getElementById('rollno').value.trim();
                const captchaInput = document.getElementById('captchaInput').value.trim();
                const captcha = document.getElementById('generatedCaptcha').dataset.value;

                if (!rollcode) {
                    showError('rollcodeError', 'Please Enter Roll Code');
                    isValid = false;
                }

                if (!rollno) {
                    showError('rollnoError', 'Please Enter Roll Number');
                    isValid = false;
                }

                if (!captchaInput) {
                    showError('captchaError', 'Please Enter CAPTCHA');
                    isValid = false;
                } else if (captchaInput !== captcha) {
                    showError('captchaError', 'Incorrect CAPTCHA');
                    generateCaptcha();
                    isValid = false;
                }

                return isValid;
            };
        });
    </script>
</body>
@if (TempData["SwalMessage"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            Swal.fire({
                icon: '@TempData["SwalType"]',
                title: '@TempData["SwalTitle"]',
                text: '@TempData["SwalMessage"]',
                confirmButtonColor: '#3085d6',
                confirmButtonText: 'OK'
            });
        });
    </script>
}
</html>